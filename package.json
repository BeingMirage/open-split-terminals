{
  "name": "open-split-terminals",
  "displayName": "Open Split Terminals",
  "description": "Open selected folders in split integrated terminals",
  "version": "0.0.1",
  "publisher": "your-publisher-name",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/open-split-terminals.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "open-split-terminals.openSplitTerminals",
        "title": "Open in Split Integrated Terminals"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "open-split-terminals.openSplitTerminals",
          "when": "explorerResourceIsFolder && listMultiSelection",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "^16.11.7",
    "typescript": "^4.9.3"
  }
}
